# Application
APP_NAME=behavioral-predictor
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/behavioral_predictor
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ML Training
ML_MODEL_DIR=./models
ML_BATCH_SIZE=256
ML_EPOCHS=50
ML_LEARNING_RATE=0.001
ML_SEQUENCE_LENGTH=20
ML_EMBEDDING_DIM=32
ML_TRANSFORMER_HEADS=4
ML_TRANSFORMER_LAYERS=2
ML_TRANSFORMER_FF_DIM=128
ML_DROPOUT=0.1

# Model Compression
COMPRESSION_QUANTIZE=true
COMPRESSION_PRUNE=true
COMPRESSION_PRUNE_AMOUNT=0.3
COMPRESSION_TARGET_SIZE_MB=1.0

# Data
DATA_DIR=../dataset/EventsData
DATA_SAMPLE_USERS=5000
DATA_CHUNK_SIZE=50000

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
